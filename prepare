#!/usr/bin/env bash
set -euo pipefail
  
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="${VENV_DIR:-$ROOT_DIR/.venv}"
PYTHON_BIN="${PYTHON_BIN:-python3}"
TOOLS_DIR="${TOOLS_DIR:-$ROOT_DIR/.tools}"
SAMPLE_PROBLEM="${SAMPLE_PROBLEM:-Place 8 queens on an 8x8 chessboard such that no two queens threaten each other. No two queens can share the same row, column, or diagonal.}"
OLLAMA_MODEL="${OLLAMA_MODEL:-${MODEL_NAME:-llama3.1}}"
JDK_MAJOR="${JDK_MAJOR:-17}"
MAVEN_VERSION="${MAVEN_VERSION:-3.9.9}"
RUN_PIPELINE=1
LOCAL_MODE=0
SKIP_SYSTEM_INSTALL=0

print_usage() {
  cat <<'EOF'
Usage: ./prepare [options]

Options:
  --install-only       Install dependencies only; skip pipeline smoke run
  --local              Run pipeline in Ollama local mode (passes --local to run.py)
  --no-system-install  Never run apt-get; rely on already installed tools
  --problem "TEXT"     Override the sample CSP problem for smoke run
  -h, --help           Show this help

Environment variables:
  VENV_DIR             Virtual environment path (default: ./.venv)
  PYTHON_BIN           Python executable to use (default: python3)
  TOOLS_DIR            Local tools folder used for non-sudo installs (default: ./.tools)
  SAMPLE_PROBLEM       Default sample problem text

Notes:
  - This script targets Ubuntu/Debian (uses apt-get).
  - Choco Solver is fetched automatically as a Maven dependency.
  - If you are not root/sudoer, system install is skipped automatically.
EOF
}

install_user_jdk() {
  if command -v java >/dev/null 2>&1; then
    return
  fi

  mkdir -p "$TOOLS_DIR"
  local archive="$TOOLS_DIR/jdk${JDK_MAJOR}.tar.gz"
  local tmp_dir
  tmp_dir="$(mktemp -d)"

  echo "[1/6] Installing Java ${JDK_MAJOR} locally in $TOOLS_DIR"
  curl -fsSL "https://api.adoptium.net/v3/binary/latest/${JDK_MAJOR}/ga/linux/x64/jdk/hotspot/normal/eclipse" -o "$archive"
  tar -xzf "$archive" -C "$tmp_dir"

  local extracted
  extracted="$(find "$tmp_dir" -maxdepth 1 -type d -name 'jdk-*' | head -n1)"
  if [[ -z "$extracted" ]]; then
    echo "Error: failed to extract JDK archive." >&2
    rm -rf "$tmp_dir" "$archive"
    exit 1
  fi

  rm -rf "$TOOLS_DIR/jdk"
  mv "$extracted" "$TOOLS_DIR/jdk"
  rm -rf "$tmp_dir" "$archive"

  export JAVA_HOME="$TOOLS_DIR/jdk"
  export PATH="$JAVA_HOME/bin:$PATH"
}

install_user_maven() {
  if command -v mvn >/dev/null 2>&1; then
    return
  fi

  mkdir -p "$TOOLS_DIR"
  local archive="$TOOLS_DIR/apache-maven-${MAVEN_VERSION}-bin.tar.gz"
  local tmp_dir
  tmp_dir="$(mktemp -d)"

  echo "[1/6] Installing Maven ${MAVEN_VERSION} locally in $TOOLS_DIR"
  curl -fsSL "https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.tar.gz" -o "$archive"
  tar -xzf "$archive" -C "$tmp_dir"

  local extracted
  extracted="$(find "$tmp_dir" -maxdepth 1 -type d -name 'apache-maven-*' | head -n1)"
  if [[ -z "$extracted" ]]; then
    echo "Error: failed to extract Maven archive." >&2
    rm -rf "$tmp_dir" "$archive"
    exit 1
  fi

  rm -rf "$TOOLS_DIR/maven"
  mv "$extracted" "$TOOLS_DIR/maven"
  rm -rf "$tmp_dir" "$archive"

  export MAVEN_HOME="$TOOLS_DIR/maven"
  export PATH="$MAVEN_HOME/bin:$PATH"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --install-only)
      RUN_PIPELINE=0
      shift
      ;;
    --local)
      LOCAL_MODE=1
      shift
      ;;
    --no-system-install)
      SKIP_SYSTEM_INSTALL=1
      shift
      ;;
    --problem)
      shift
      if [[ $# -eq 0 ]]; then
        echo "Error: --problem requires a value." >&2
        exit 1
      fi
      SAMPLE_PROBLEM="$1"
      shift
      ;;
    -h|--help)
      print_usage
      exit 0
      ;;
    *)
      echo "Error: Unknown argument '$1'." >&2
      print_usage
      exit 1
      ;;
  esac
done

if [[ ! -f "$ROOT_DIR/run.py" ]]; then
  echo "Error: run.py not found. Execute this script from the project root." >&2
  exit 1
fi

if ! command -v apt-get >/dev/null 2>&1; then
  echo "Error: apt-get not found. This script currently supports Ubuntu/Debian only." >&2
  exit 1
fi

# Prefer local tools first if they already exist from a previous run.
if [[ -x "$TOOLS_DIR/jdk/bin/java" ]]; then
  export JAVA_HOME="$TOOLS_DIR/jdk"
  export PATH="$JAVA_HOME/bin:$PATH"
fi
if [[ -x "$TOOLS_DIR/maven/bin/mvn" ]]; then
  export MAVEN_HOME="$TOOLS_DIR/maven"
  export PATH="$MAVEN_HOME/bin:$PATH"
fi

CAN_APT_INSTALL=0
SUDO=""
if [[ "$SKIP_SYSTEM_INSTALL" -eq 0 ]]; then
  if [[ "${EUID}" -eq 0 ]]; then
    CAN_APT_INSTALL=1
  elif command -v sudo >/dev/null 2>&1 && sudo -n true >/dev/null 2>&1; then
    SUDO="sudo"
    CAN_APT_INSTALL=1
  fi
fi

if [[ "$CAN_APT_INSTALL" -eq 1 ]]; then
  echo "[1/6] Installing system dependencies (Java 17, Maven, Python venv)"
  $SUDO apt-get update
  $SUDO DEBIAN_FRONTEND=noninteractive apt-get install -y \
    openjdk-17-jdk \
    maven \
    python3 \
    python3-venv \
    python3-pip \
    curl
else
  echo "[1/6] Skipping apt install (no root/sudo privileges or --no-system-install)"
  echo "      Will use already installed tools from your user environment."

  if ! command -v curl >/dev/null 2>&1 || ! command -v tar >/dev/null 2>&1; then
    echo "Error: curl and tar are required for non-sudo local tool installation." >&2
    exit 1
  fi

  install_user_jdk
  install_user_maven
fi

MISSING=0
for cmd in java mvn python3 curl tar; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Error: required command not found: $cmd" >&2
    MISSING=1
  fi
done
if [[ "$MISSING" -ne 0 ]]; then
  cat >&2 <<'EOF'
Install missing tools using one of these options:
  1) Ask admin to run: apt-get install -y openjdk-17-jdk maven python3 python3-venv python3-pip curl tar
  2) Re-run this script as root/sudoer
  3) Re-run with --no-system-install after ensuring python3/curl/tar exist
EOF
  exit 1
fi

echo "[2/6] Verifying Java and Maven"
java -version
mvn -version

echo "[3/6] Creating/updating Python virtual environment"
if [[ ! -d "$VENV_DIR" ]]; then
  "$PYTHON_BIN" -m venv "$VENV_DIR"
fi

# shellcheck disable=SC1091
source "$VENV_DIR/bin/activate"
python -m pip install --upgrade pip setuptools wheel
python -m pip install -r "$ROOT_DIR/requirements.txt"

echo "[4/6] Ensuring Choco artifacts are downloaded"
mvn -q -f "$ROOT_DIR/choco_runner/pom.xml" -DskipTests compile

echo "[5/6] Environment sanity check"
if [[ ! -f "$ROOT_DIR/.env" ]]; then
  cat <<'EOF'
Warning: .env file not found.
Create one before non-local runs with at least:
  LLM_PROVIDER=gemini|openai|groq|ollama
  MODEL_NAME=<model>
  API key for provider (for example GOOGLE_API_KEY or OPENAI_API_KEY)
EOF
fi

if [[ "$LOCAL_MODE" -eq 1 ]]; then
  echo "[local] Ensuring Ollama is installed and reachable"
  if ! command -v ollama >/dev/null 2>&1; then
    echo "Error: ollama command not found." >&2
    echo "Install Ollama first (user-level or admin install), then rerun with --local." >&2
    echo "Alternative: set OLLAMA_HOST to a remote Ollama server and run again." >&2
    exit 1
  fi

  if ! curl -fsS http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
    nohup ollama serve >/tmp/ollama.log 2>&1 &
    sleep 2
  fi

  if ! curl -fsS http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
    echo "Error: Ollama could not be started. Check /tmp/ollama.log" >&2
    exit 1
  fi

  echo "[local] Pulling Ollama model: $OLLAMA_MODEL"
  ollama pull "$OLLAMA_MODEL"
fi

if [[ "$RUN_PIPELINE" -eq 1 ]]; then
  echo "[6/6] Running pipeline smoke test"
  if [[ "$LOCAL_MODE" -eq 1 ]]; then
    python "$ROOT_DIR/run.py" --local "$SAMPLE_PROBLEM"
  else
    python "$ROOT_DIR/run.py" "$SAMPLE_PROBLEM"
  fi
else
  echo "[6/6] Skipping pipeline smoke test (--install-only)"
fi

echo "Prepare completed successfully."
